{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "skipLibCheck": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true
  },
  "include": ["src"]
}
