{
  "name": "@yongstack/openapi-fetch",
  "description": "Fast, type-safe fetch client for your OpenAPI schema.",
  "version": "0.17.0",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1"
  },
  "publishConfig": {
    "access": "public"
  }
