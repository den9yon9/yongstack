{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NODE_ENV", "DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", ".env.*local"],
      "outputs": ["dist/**", ".output/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"]
    },
    "gen": {
      "cache": false,
      "outputs": []
    },
    "watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@yongstack/api#dev"]
    }
  }
}
