{
  "name": "yongstack",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && tsc -b",
    "test": "turbo run test",
    "check": "biome check --write --diagnostic-level=error .",
    "repomix": "pnpx repomix",
    "prepare": "husky",
    "gen": "turbo run gen"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css,scss,less}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@biomejs/biome": "2.3.7",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@sinclair/typebox": ">= 0.34.0 < 1",
    "elysia": "^1.4.16"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "version": "1.3.2",
      "onFail": "download"
    }
  },
  "dependencies": {
    "@types/bun": "^1.3.11"
  }
}
